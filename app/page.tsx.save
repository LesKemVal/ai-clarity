'use client'

import { useCallback, useEffect, useMemo, useRef, useState } from 'react'
import Sidebar from '@/components/Sidebar'

  role: 'assistant' | 'user'
  content: string
}

declare global {
  interface Window {
    webkitSpeechRecognition?: any
    SpeechRecognition?: any
  export default function Page() {
  const [input, setInput] = useState('')
  const [messages, setMessages] = useState<Message[]>([
    { role: 'assistant', content: 'Ask me anything.' },
  ])
  const [interimTranscript, setInterimTranscript] = useState('')
  const [voiceError, setVoiceError] = useState('')
  const [voiceSupported, setVoiceSupported] = useState(false)
  const [voiceActive, setVoiceActive] = useState(false)
  const [voiceReplyOn, setVoiceReplyOn] = useState(true)
  const [isListening, setIsListening] = useState(false)
  const [isThinking, setIsThinking] = useState(false)
  const [isSpeaking, setIsSpeaking] = useState(false)
  const [audioUnlocked, setAudioUnlocked] = useState(false)

  const recognitionRef = useRef<SpeechRecognitionInstance | null>(null)
  const speakingRef = useRef(false)
  const messagesRef = useRef<Message[]>([
    { role: 'assistant', content: 'Ask me anything.' },
  ])

  useEffect(() => {
    messagesRef.current = messages
  }, [messages])

  const SpeechRecognitionCtor = useMemo(() => {
    if (typeof window === 'undefined') return null
    return window.SpeechRecognition || window.webkitSpeechRecognition || null
  }, [])

  useEffect(() => {
    const unlockAudio = () => {
      if (audioUnlocked) return
      if ('speechSynthesis' in window) {
        const utterance = new SpeechSynthesisUtterance('')
        window.speechSynthesis.speak(utterance)
        window.speechSynthesis.cancel()
      }
      setAudioUnlocked(true)
    }

    window.addEventListener('click', unlockAudio)
    window.addEventListener('touchstart', unlockAudio)

    return () => {
      window.removeEventListener('click', unlockAudio)
      window.removeEventListener('touchstart', unlockAudio)
    }
  }, [audioUnlocked])

  const stopListening = useCallback(() => {
    recognitionRef.current?.stop?.()
    setIsListening(false)
  }, [])

  const startListening = useCallback(() => {
    if (!recognitionRef.current) {
      setVoiceError('Voice input is not supported in this browser.')
      return
    }

    if (isListening || isThinking || speakingRef.current) return

    setVoiceError('')
    setInterimTranscript('')

    try {
      recognitionRef.current.start()
    } catch {
      // ignore browser timing collisions
    }
  }, [isListening, isThinking])

  const speakText = useCallback(
    (text: string) => {
      if (typeof window === 'undefined') return

      if (!voiceReplyOn) {
        if (voiceActive) {
          setTimeout(() => {
            startListening()
          }, 250)
        }
        return
      }

      if (!('speechSynthesis' in window)) {
        setVoiceError('Voice reply is not supported in this browser.')
        return
      }

      const synth = window.speechSynthesis
      synth.cancel()

      const utterance = new SpeechSynthesisUtterance(text)
      utterance.lang = 'en-US'
      utterance.rate = 1
      utterance.pitch = 0.95

      const voices = synth.getVoices()
      const preferredVoice =
        voices.find((voice) =>
          /alex|david|daniel|fred|google us english|microsoft david/i.test(voice.name)
        ) ||
        voices.find((voice) => voice.lang?.toLowerCase().startsWith('en-us')) ||
        voices.find((voice) => voice.lang?.toLowerCase().startsWith('en')) ||
        voices[0]

      if (preferredVoice) {
        utterance.voice = preferredVoice
      }

      utterance.onstart = () => {
        speakingRef.current = true
        setIsSpeaking(true)
        setVoiceError('')
      }

      utterance.onend = () => {
        speakingRef.current = false
        setIsSpeaking(false)

        if (voiceActive) {
          setTimeout(() => {
            startListening()
          }, 250)
        }
      }

      utterance.onerror = () => {
        speakingRef.current = false
        setIsSpeaking(false)
        setVoiceError('Voice reply failed.')
      }

      synth.speak(utterance)
    },
    [voiceActive, voiceReplyOn, startListening]
  )

  const handleSend = useCallback(
    async (overrideText?: string) => {
      const text = (overrideText ?? input).trim()
      if (!text || isThinking) return

      stopListening()

      const userMessage: Message = {
        role: 'user',
        content: text,
      }

      const updatedMessages = [...messagesRef.current, userMessage]

      setMessages(updatedMessages)
      messagesRef.current = updatedMessages
      setInput('')
      setInterimTranscript('')
      setVoiceError('')
      setIsThinking(true)

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: updatedMessages,
            voiceMode: true,
            isFirstSession: messagesRef.current.length <= 2,
          }),
        })

        const data = await res.json()

        if (!res.ok) {
          throw new Error(data?.error || 'Request failed')
        }

        const assistantMessage: Message = {
          role: 'assistant',
          content: data.message,
        }

        setMessages((prev) => {
          const next = [...prev, assistantMessage]
          messagesRef.current = next
          return next
        })

        speakText(assistantMessage.content)
      } catch {
        setVoiceError('Response failed.')
      } finally {
        setIsThinking(false)
      }
    },
    [input, isThinking, speakText, stopListening]
  )

  useEffect(() => {
    setVoiceSupported(Boolean(SpeechRecognitionCtor))
    if (!SpeechRecognitionCtor) return

    const recognition = new SpeechRecognitionCtor()
    recognition.lang = 'en-US'
    recognition.continuous = false
    recognition.interimResults = true
    recognition.maxAlternatives = 1

    recognition.onstart = () => {
      setVoiceError('')
      setIsListening(true)
    }

      recognition.onresult = (event: SpeechRecognitionEventLike) => {
      let finalTranscript = ''
      let liveTranscript = ''

      for (let i = event.resultIndex; i < event.results.length; i += 1) {
        const transcript = event.results[i][0]?.transcript ?? ''
        if (event.results[i].isFinal) {
          finalTranscript += transcript
        } else {
          liveTranscript += transcript
        }
      }

      setInterimTranscript(liveTranscript)

      if (finalTranscript.trim()) {
        handleSend(finalTranscript.trim())
      }
    }

      recognition.onerror = (event: SpeechRecognitionErrorLike) => {
      const message =
        event?.error === 'not-allowed'
          ? 'Microphone permission was denied.'
          : event?.error === 'audio-capture'
            ? 'No microphone was available.'
            : event?.error === 'no-speech'
              ? ''
              : 'Voice input failed.'

      if (message) {
        setVoiceError(message)
      }

      setIsListening(false)
    }

    recognition.onend = () => {
      setIsListening(false)
      setInterimTranscript('')

      if (voiceActive && !isThinking && !speakingRef.current) {
        setTimeout(() => {
          startListening()
        }, 250)
      }
    }

    recognitionRef.current = recognition

    return () => {
      recognition.stop?.()
      recognitionRef.current = null
    }
  }, [SpeechRecognitionCtor, handleSend, isThinking, startListening, voiceActive])

  const effectiveInput = interimTranscript
    ? `${input}${input ? ' ' : ''}${interimTranscript}`
    : input

  const statusText = voiceError
    ? voiceError
    : isSpeaking
      ? 'GEORGE is speaking...'
      : isThinking
        ? 'GEORGE is thinking...'
        : isListening
          ? 'GEORGE is listening...'
          : voiceActive
            ? 'Voice loop is active.'
            : 'Voice loop is paused.'

  return (
    <main className="h-screen overflow-hidden bg-black text-neutral-100">
      <div className="mx-auto flex h-screen max-w-[1600px]">
<Sidebar
  voiceActive={voiceActive}
  onNewSession={() => {
    setMessages([{ role: 'assistant', content: 'Ask me anything.' }])
    messagesRef.current = [{ role: 'assistant', content: 'Ask me anything.' }]
  }}
/>
        <div className="flex min-w-0 flex-1 flex-col">

          <div className="flex h-screen flex-col px-4 pb-4 pt-16 md:px-6">
            <header className="flex-none border-b border-neutral-800 pb-4">
              <h1 className="text-3xl font-semibold tracking-tight md:text-4xl">
                GEORGE
              </h1>
              <p className="text-neutral-400">Clarity. Execution. Continuity.</p>
            </header>

            <section className="mt-4 grid flex-none gap-3 md:grid-cols-3">
              <div className="rounded-2xl border border-neutral-800 bg-neutral-950 p-4">
                <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                  PRIMARY
                </p>
                <p className="mt-2 text-sm text-neutral-300">
                  Decide what matters most.
                </p>
              </div>

              <div className="rounded-2xl border border-neutral-800 bg-neutral-950 p-4">
                <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                  SECONDARY
                </p>
                <p className="mt-2 text-sm text-neutral-300">
                  Acknowledge multiple objectives.
                </p>
              </div>

              <div className="rounded-2xl border border-neutral-800 bg-neutral-950 p-4">
                <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                  SIGNAL
                </p>
                <p className="mt-2 text-sm text-neutral-300">
                  Measure progress.
                </p>
              </div>
            </section>

            <section className="mt-4 flex min-h-0 flex-1 flex-col overflow-hidden rounded-2xl border border-neutral-800 bg-black">
              <div className="flex-1 overflow-y-auto p-4">
                <div className="space-y-4">
                  {messages.map((m, i) => (
                    <div
                      key={i}
                      className={`flex w-full ${m.role === 'user' ? 'justify-end' : 'justify-start'}`}
                    >
                      <div
                        className={`max-w-[75%] rounded-2xl border px-4 py-3 ${
                          m.role === 'user'
                            ? 'border-amber-400/40 bg-amber-400/10 text-neutral-100'
                            : 'border-neutral-700 bg-neutral-950 text-neutral-100'
                        }`}
                      >
                        <p className="mb-1 text-[11px] uppercase tracking-[0.18em] opacity-60">
                          {m.role === 'user' ? 'YOU' : 'GEORGE'}
                        </p>
                        <p className="whitespace-pre-wrap text-sm leading-7">{m.content}</p>
                      </div>
                    </div>
                  ))}

                  {isThinking && (
                    <div className="flex w-full justify-start">
                      <div className="max-w-[75%] rounded-2xl border border-neutral-700 bg-neutral-950 px-4 py-3 text-neutral-400">
                        <p className="mb-1 text-[11px] uppercase tracking-[0.18em] opacity-60">
                          GEORGE
                        </p>
                        <p className="text-sm leading-7">Thinking...</p>
                      </div>
                    </div>
                  )}
                </div>
              </div>

              <div className="flex-none border-t border-neutral-800 p-4">
                <textarea
                  value={effectiveInput}
                  onChange={(e) => setInput(e.target.value)}
                  placeholder="Lay it on me."
                  rows={2}
                  className="w-full resize-none rounded-2xl border border-neutral-800 bg-black px-4 py-3 text-sm text-neutral-100 outline-none placeholder:text-neutral-500 focus:border-amber-400"
                />

                <div className="mt-3 flex flex-wrap items-center justify-between gap-3">
                  <div className="flex flex-wrap items-center gap-2">
                    <button
                      type="button"
                      onClick={() => {
                        if (voiceActive) {
                          setVoiceActive(false)
                          stopListening()
                          if ('speechSynthesis' in window) {
                            window.speechSynthesis.cancel()
                          }
                          speakingRef.current = false
                          setIsSpeaking(false)
                        } else {
                          setVoiceActive(true)
                          setVoiceError('')
                          startListening()
                        }
                      }}
                      disabled={!voiceSupported || isThinking}
                      className="rounded-full border border-neutral-700 px-4 py-2 text-sm text-neutral-200 transition hover:border-amber-400 hover:text-amber-300 disabled:cursor-not-allowed disabled:opacity-40"
                    >
                      {voiceActive ? 'Pause voice loop' : 'Activate voice loop'}
                    </button>

                    <button
                      type="button"
                      onClick={() => setVoiceReplyOn((prev) => !prev)}
                      className="rounded-full border border-neutral-700 px-4 py-2 text-sm text-neutral-200 transition hover:border-amber-400 hover:text-amber-300"
                    >
                      {voiceReplyOn ? 'Voice reply on' : 'Voice reply off'}
                    </button>
                  </div>

                  <button
                    onClick={() => handleSend()}
                    disabled={isThinking}
                    className="rounded-full bg-amber-400 px-5 py-2 text-sm text-black disabled:cursor-not-allowed disabled:opacity-50"
                  >
                    Send
                  </button>
                </div>

                <div className="mt-3 min-h-[1.5rem] text-sm text-neutral-500">
                  <span className={voiceError ? 'text-red-400' : ''}>{statusText}</span>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>
  )
}
